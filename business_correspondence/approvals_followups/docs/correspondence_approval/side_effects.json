{
  "submit": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "in_review",
        "submission_status": "submitted"
      }
    }
  ],
  "approve": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "approved"
      }
    },
    {
      "type": "create_record",
      "target_doc": "correspondence_record",
      "values": {
        "title": {
          "$template": "Correspondence Record for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "CORRESPONDENCE_RECORD-{reference_no|id}"
        }
      }
    }
  ],
  "close": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "closed"
      }
    }
  ]
}
